# Homebase Kinnect — required environment variables
#
# Copy this file to `.env.local` and fill in real values, and set the same
# keys in the Vercel project (Settings → Environment Variables).
# NEVER commit `.env.local` — it holds the service-account private key.

# --- Google service account (shared read access to the Sheet / Calendar / Drive folder) ---
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# Paste the full key as one line with literal \n escapes, wrapped in quotes:
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- Data sources ---
# Google Sheet holding the meal plan + grocery data
GOOGLE_SPREADSHEET_ID=
# Google Calendar read for the day's schedule
GOOGLE_CALENDAR_ID=
# Google Drive folder holding the rotating family "Memories" photos
GOOGLE_DRIVE_FOLDER_ID=
